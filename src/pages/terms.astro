---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout
	title="Terms of Service - Flashtools"
	description="Terms of service for Flashtools, the free client-side PNG to WebP converter."
	canonicalPath="/terms"
>
	<Header />

	<main class="legal-layout">
		<h1>Terms of Service</h1>
		<p class="updated">Last updated: July 6, 2026</p>

		<section>
			<h2>The service</h2>
			<p>
				Flashtools is a free tool that converts PNG images to WebP format locally in your
				web browser. Because the conversion runs entirely on your device, you remain in
				full control and full possession of your files at all times.
			</p>
		</section>

		<section>
			<h2>Acceptable use</h2>
			<p>
				You may use Flashtools for any lawful purpose, personal or commercial. You retain
				all rights to the images you convert — we never receive them and claim no rights
				over them or their converted output.
			</p>
		</section>

		<section>
			<h2>No warranty</h2>
			<p>
				Flashtools is provided "as is", without warranty of any kind. Conversion quality
				and browser compatibility depend on your browser's implementation of the Canvas
				and WebP encoding APIs. Always keep your original files; we are not liable for any
				loss or damage arising from use of this tool.
			</p>
		</section>

		<section>
			<h2>Changes</h2>
			<p>
				We may update these terms from time to time. Continued use of the site after
				changes constitutes acceptance of the updated terms.
			</p>
		</section>

		<p><a href="/" class="back-link">&larr; Back to converter</a></p>
	</main>
</Layout>

<style>
	.legal-layout {
		flex-grow: 1;
		width: 100%;
		max-width: 760px;
		margin: 0 auto;
		padding: 3rem 2rem 5rem 2rem;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		z-index: 10;
	}

	h1 {
		font-size: 2.25rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--color-text);
	}

	.updated {
		font-size: 0.85rem;
		color: var(--color-text-dim);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	h2 {
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--color-text);
	}

	p {
		font-size: 0.95rem;
		color: var(--color-text-muted);
		line-height: 1.7;
	}

	a {
		color: var(--color-primary);
	}

	.back-link {
		text-decoration: none;
		font-weight: 500;
	}
</style>
